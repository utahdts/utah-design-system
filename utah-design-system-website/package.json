{
  "name": "utah-design-system-website",
  "private": true,
  "version": "5.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development-local",
    "build": "vite build --mode production-website",
    "buildw": "vite build --watch --mode production-website",
    "eslint": "npx eslint",
    "eslintw": "npx eslint-watch -w",
    "preview": "vite preview",
    "publishLibrary": "npm publish --access public",
    "test": "vitest",
    "testw": "vitest",
    "testc": "vitest run --coverage",
    "tsc": "tsc",
    "tscw": "tsc --watch --skipLibCheck",
    "watch": "vite watch",
    "testOnce": "vitest run"
  },
  "dependencies": {
    "@utahdts/utah-design-system": "5.0.1",
    "@utahdts/utah-design-system-header": "5.0.1",
    "date-fns": "4.1.0",
    "js-beautify": "1.15.4",
    "lodash-es": "4.18.1",
    "prop-types": "15.8.1",
    "react": "^19.2.5",
    "react-colorful": "5.6.1",
    "react-router-dom": "^7.14.2",
    "tinycolor2": "1.6.0",
    "use-immer": "0.11.0"
  },
  "devDependencies": {
    "@types/js-beautify": "1.14.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "1.4.6",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "sass": "^1.99.0",
    "vite": "^8.0.10",
    "vite-plugin-eslint": "1.8.1",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^4.1.5"
  },
  "eslint.workingDirectories": [
    "./src",
    "./test"
  ]
}
